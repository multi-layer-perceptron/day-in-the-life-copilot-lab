@model PaginatedList<Student>

@{
    ViewBag.Title = "Students";
}

<h2>Students</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<form asp-action="Index" method="get">
    <div class="row g-3 align-items-end mb-3">
        <div class="col-md-4">
            <label for="lastNameSearch" class="form-label">Last name</label>
            <input id="lastNameSearch" type="text" name="lastNameSearch" value="@ViewBag.CurrentLastNameFilter" class="form-control" />
        </div>
        <div class="col-md-4">
            <label for="firstNameSearch" class="form-label">First name</label>
            <input id="firstNameSearch" type="text" name="firstNameSearch" value="@ViewBag.CurrentFirstNameFilter" class="form-control" />
        </div>
        <div class="col-md-4">
            <input type="submit" value="Search" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-secondary">Back to Full List</a>
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewBag.NameSortParm"
                   asp-route-currentLastNameFilter="@ViewBag.CurrentLastNameFilter"
                   asp-route-currentFirstNameFilter="@ViewBag.CurrentFirstNameFilter">Full Name</a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewBag.DateSortParm"
                   asp-route-currentLastNameFilter="@ViewBag.CurrentLastNameFilter"
                   asp-route-currentFirstNameFilter="@ViewBag.CurrentFirstNameFilter">Enrollment Date</a>
            </th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.FullName
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.EnrollmentDate)
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-info btn-sm">Details</a> |
                    <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-warning btn-sm">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Removed prevDisabled and nextDisabled variables; using inline conditionals in button classes below. *@

<a asp-action="Index" 
   asp-route-sortOrder="@ViewBag.CurrentSort" 
    asp-route-pageNumber="@(Model.PageIndex - 1)" 
    asp-route-currentLastNameFilter="@ViewBag.CurrentLastNameFilter"
    asp-route-currentFirstNameFilter="@ViewBag.CurrentFirstNameFilter"
    class="btn btn-secondary @(Model.HasPreviousPage ? "" : "disabled")">
   Previous
</a>

<a asp-action="Index" 
   asp-route-sortOrder="@ViewBag.CurrentSort" 
    asp-route-pageNumber="@(Model.PageIndex + 1)" 
    asp-route-currentLastNameFilter="@ViewBag.CurrentLastNameFilter"
    asp-route-currentFirstNameFilter="@ViewBag.CurrentFirstNameFilter"
    class="btn btn-secondary @(Model.HasNextPage ? "" : "disabled")">
   Next
</a>
